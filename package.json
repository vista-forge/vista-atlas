{
  "name": "vista-atlas",
  "version": "0.1.0",
  "description": "VistA Atlas — VSCode extension over the vdocs gold-corpus data release: faceted library, FTS5 search, reading pane with table/figure hydration, entity pages. What the VA documentation SAYS.",
  "type": "module",
  "main": "./dist/extension.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=24",
    "vscode": "^1.125.0"
  },
  "scripts": {
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "test:watch": "node --import tsx --test --watch 'src/**/*.test.ts'",
    "test:cov": "c8 --reporter=text --reporter=lcov node --import tsx --test 'src/**/*.test.ts'",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "audit": "npm audit --audit-level=high",
    "check": "npm run lint && npm run typecheck && npm run test:cov && npm run audit && npm run bundle",
    "prepublishOnly": "npm run build",
    "bundle": "esbuild src/ext/extension.ts --bundle --outfile=dist/extension.cjs --external:vscode --platform=node --format=cjs --sourcemap",
    "bundle:smoke": "esbuild src/smoke/suite.ts --bundle --outfile=dist/smoke-suite.cjs --external:vscode --platform=node --format=cjs",
    "test:vscode": "npm run bundle && npm run bundle:smoke && node --import tsx src/smoke/run.ts",
    "vscode:prepublish": "npm run bundle",
    "vsix": "vsce package --no-dependencies"
  },
  "license": "MIT",
  "author": "Rafael Richards",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.125.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "c8": "^10.1.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vista-forge/vista-atlas"
  },
  "displayName": "VistA Atlas",
  "publisher": "vista-forge",
  "icon": "media/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onUri"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vistaAtlas.open",
        "title": "VistA Atlas: Open Navigator"
      },
      {
        "command": "vistaAtlas.reloadData",
        "title": "VistA Atlas: Reload Data (re-verify release)"
      }
    ],
    "configuration": {
      "title": "VistA Atlas",
      "properties": {
        "vistaAtlas.dataPath": {
          "type": "string",
          "default": "",
          "description": "Path to a local directory containing index.db (an extracted release root, or the dist staging copy). Empty: fetch-verify the published release bundle into global storage."
        },
        "vistaAtlas.assetsDir": {
          "type": "string",
          "default": "",
          "description": "Optional path to a content-addressed image store (documents/assets) for figure display. Empty: figures 404 until rich-assets ship in the data release."
        }
      }
    }
  }
}
